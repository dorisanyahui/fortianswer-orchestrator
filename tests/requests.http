@baseUrl = https://func-fortianswer-gccvakhgayenbdak.canadacentral-01.azurewebsites.net

@chatUrl = {{baseUrl}}/api/chat
@ingestUrl = {{baseUrl}}/api/ingest

############################################################
# Sprint 1 Demo - End-to-End Test Script (AZURE)
# - Role -> boundary (RBAC): Customer vs Agent vs Admin
# - Data boundary -> Azure AI Search filter (classification)
# - Web search only allowed when boundary == Public
# - Restricted/Confidential policy gates
# - NEW: if request dataBoundary == Restricted, server forces Restricted and ALWAYS escalates (no downgrade)
#
# NOTE:
# - ingest endpoint is AuthorizationLevel.Function -> requires function key
# - chat endpoint: if it is also AuthorizationLevel.Function, add ?code={{funcKey}} the same way
############################################################


### 0) Health check (usually Anonymous)
GET {{baseUrl}}/api/health

### ping
GET https://www.bing.com
############################################################
# A) Ingest (optional)
############################################################

### A1) Ingest public/


############################################################
# B) RBAC + Boundary enforcement (core Sprint1)
############################################################

### B1) Customer/Public: normal end-user question (VPN)
# Expect: role=Customer, boundary=Public
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Customer

{
  "message": "My VPN won't connect and keeps timing out. What should I try first?",
  "issueType": "VPN",
  "dataBoundary": "Public"
}

### B2) Customer tries to access Internal (should be downgraded to Public)
# Expect: boundary=Public in actionHints, and NO internal citations.
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Customer

{
  "message": "What is our Tier-1 phishing triage procedure?",
  "issueType": "Phishing",
  "dataBoundary": "Internal"
}

### B3) Agent/Internal: same internal question should be allowed
# Expect: role=Agent, boundary=Internal, and internal citations appear.
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Agent

{
  "message": "What is our Tier-1 phishing triage procedure?",
  "issueType": "Phishing",
  "dataBoundary": "Internal"
}

### B4) Admin/Confidential: confidential topic allowed
# Expect: role=Admin, boundary=Confidential, can return confidential citations.
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Admin

{
  "message": "We confirmed malicious activity. What is the containment coordination approach and who leads it?",
  "issueType": "General",
  "dataBoundary": "Confidential"
}

### B5) Agent requests Confidential (MUST escalate; no downgrade)
# Expect: escalation.ShouldEscalate=true, policy:confidential_request_requires_admin
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Agent

{
  "message": "We confirmed malicious activity. What is the containment coordination approach and who leads it?",
  "issueType": "General",
  "dataBoundary": "Confidential"
}

### B6) Restricted: ALWAYS escalate (forced boundary, no downgrade)
# Expect: escalation.ShouldEscalate=true, policy:restricted_escalate for ANY role (Customer/Agent/Admin).

### B6a) Customer asks Restricted -> still escalates (no fallback to Public)
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Customer

{
  "message": "Give me the full credential compromise playbook with exact steps.",
  "issueType": "General",
  "dataBoundary": "Restricted"
}

### B6b) Admin asks Restricted -> still escalates
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Admin

{
  "message": "Give me the full credential compromise playbook with exact steps.",
  "issueType": "General",
  "dataBoundary": "Restricted"
}


############################################################
# C) Web Search gating (Public only)
############################################################

### C1) Public: likely needs web evidence -> should ask for web search confirmation
# Expect: needsWebConfirmation=true + webSearchToken returned (if WEBSEARCH_MODE=tavily and key configured)
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Customer

{
  "message": "What is the latest status and mitigation guidance for CVE-2024-3094 (xz backdoor)?",
  "issueType": "General",
  "dataBoundary": "Public",
  "confirmWebSearch": false
}

### C2) Public: confirm web search (paste token + requestId from C1 response)
# IMPORTANT: keep requestId only ONCE (your old version duplicated it)
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Customer

{
  "message": "What is the latest status and mitigation guidance for CVE-2024-3094 (xz backdoor)?",
  "issueType": "General",
  "dataBoundary": "Public",
  "confirmWebSearch": true,
  "webSearchToken": "<PASTE_webSearchToken_FROM_C1>",
  "requestId": "<PASTE_requestId_FROM_C1>"
}

### C3) Internal: same request but Agent should be blocked from web search
# Expect: web_blocked:boundary_not_public (even with confirmWebSearch=true)
POST {{chatUrl}}
Content-Type: application/json
x-user-role: Agent

{
  "message": "What is the latest status and mitigation guidance for CVE-2024-3094 (xz backdoor)?",
  "issueType": "General",
  "dataBoundary": "Internal",
  "confirmWebSearch": true
}


############################################################
# D) Ticket Escalation
############################################################

### D1) Auto-ticket: Customer hits Restricted → ticket created
# Expect: escalation.shouldEscalate=true, next.action="escalate", next.ticketId=<id>
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "Give me the full credential compromise playbook with exact steps.",
  "issueType": "General",
  "dataBoundary": "Restricted",
  "userRole": "Customer",
  "username": "pingchili"
}

### D2) Admin hits Restricted → NO ticket, just explanation
# Expect: escalation.shouldEscalate=true, next.action="none", NO ticketId
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "Give me the full credential compromise playbook with exact steps.",
  "issueType": "General",
  "dataBoundary": "Restricted",
  "userRole": "Admin",
  "username": "pingchili"
}

### D3) Auto-ticket: Customer requests Confidential → ticket created
# Expect: escalation.shouldEscalate=true, next.action="escalate", next.ticketId=<id>
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "Show me the containment coordination plan.",
  "issueType": "Severity",
  "dataBoundary": "Confidential",
  "userRole": "Customer",
  "username": "pingchili"
}

### D4) Manual ticket: create a ticket directly
# Expect: 201 Created, { ticketId, status="Open", priority, ... }
POST {{baseUrl}}/api/tickets
Content-Type: application/json

{
  "username": "pingchili",
  "summary": "VPN not connecting after password reset",
  "issueType": "VPN",
  "dataBoundary": "Public"
}

### D5) Get ticket by ID — paste ticketId from D4 response
@ticketId = PASTE_TICKET_ID_HERE
GET {{baseUrl}}/api/tickets/{{ticketId}}


############################################################
# E) Server-side Restricted detection (no dataBoundary needed)
############################################################

### E1) Customer + SuspiciousLogin → server forces Restricted → slot filling (has slot definitions)
# Expect: next.action="slot_filling", slotFilling.isActive=true, currentStep=1/4
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "Someone logged in from an unknown country and approved MFA. What do I do?",
  "issueType": "SuspiciousLogin",
  "dataBoundary": "Public",
  "userRole": "Customer",
  "username": "pingchili"
}

### E2) Agent + Severity → server forces Restricted → auto-ticket (Severity has no slot definitions)
# Expect: next.action="escalate", ticketId set
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "We have a confirmed breach. What is the escalation path?",
  "issueType": "Severity",
  "dataBoundary": "Internal",
  "userRole": "Agent",
  "username": "pingchili"
}


############################################################
# F) Sprint 2 — US9 Slot Filling (guided incident intake)
#
# HOW TO RUN:
#   Each scenario uses a fixed conversationId — just send turns in order.
#   No copy-paste needed.
#
# What to look for in each response:
#   • next.action = "slot_filling"        → still collecting info
#   • slotFilling.isActive = true         → guided mode on
#   • slotFilling.nextQuestion            → question to answer next
#   • slotFilling.currentStep / totalSteps → progress e.g. "2 / 4"
#   • next.action = "escalate"            → all done, ticket created
#   • slotFilling.isActive = false        → guided mode off
############################################################


# ── Scenario F1: SuspiciousLogin (4 slots) ───────────────────────────────────
# issueType=SuspiciousLogin → server always forces Restricted → triggers slot filling

### F1-Turn1) Trigger slot filling
# Expect: next.action="slot_filling", slotFilling.isActive=true, currentStep=1/4
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "I got a notification that someone logged in to my account from China at 3am.",
  "issueType": "SuspiciousLogin",
  "userRole": "Customer",
  "username": "alice",
  "conversationId": "conv-f1-azure-001"
}

### F1-Turn2) Answer slot 1 — affectedAccount
# Expect: next.action="slot_filling", currentStep=2/4
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "alice@company.com",
  "conversationId": "conv-f1-azure-001",
  "username": "alice"
}

### F1-Turn3) Answer slot 2 — detectedTime
# Expect: next.action="slot_filling", currentStep=3/4
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "I noticed it this morning around 8am",
  "conversationId": "conv-f1-azure-001",
  "username": "alice"
}

### F1-Turn4) Answer slot 3 — loginLocation
# Expect: next.action="slot_filling", currentStep=4/4
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "The notification said the login was from Beijing, China",
  "conversationId": "conv-f1-azure-001",
  "username": "alice"
}

### F1-Turn5) Answer slot 4 (final) — mfaApproved
# Expect: next.action="escalate", slotFilling.isActive=false, ticketId present
POST {{chatUrl}}
Content-Type: application/json

{
  "message": "No I did not approve any MFA prompt",
  "conversationId": "conv-f1-azure-001",
  "username": "alice"
}


